{
  "name": "@easy-sysml/parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SysML v2 parser — Langium grammar, AST, validation, and symbol resolution",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generated": {
      "types": "./dist/generated/ast.d.ts",
      "import": "./dist/generated/ast.js"
    }
  },
  "scripts": {
    "langium:generate": "langium generate && node scripts/fix-generated.cjs",
    "build": "npm run langium:generate && tsc --build",
    "watch": "tsc --build --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "langium": "^4.2.2"
  },
  "devDependencies": {
    "langium-cli": "^4.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
