{
  "name": "@easy-sysml/language-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SysML v2 Language Server — LSP implementation with diagnostics, completion, hover, and navigation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "sysml-language-server": "./bin/sysml-language-server.js"
  },
  "scripts": {
    "build": "tsc --build",
    "watch": "tsc --build --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@easy-sysml/parser": "workspace:*",
    "langium": "^4.2.2",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
