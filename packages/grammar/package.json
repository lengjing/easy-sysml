{
  "name": "@easy-sysml/grammar",
  "version": "0.1.0",
  "type": "module",
  "license": "LGPL-3.0-or-later",
  "description": "SysML v2 / KerML grammar definitions, generated AST types, and Langium modules",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "langium:generate": "langium generate && node scripts/fix-generated.cjs",
    "build": "npm run langium:generate && tsc --build",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "langium": "~4.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "langium-cli": "~4.2.0",
    "typescript": "~5.8.3",
    "vitest": "^3.1.3"
  }
}
