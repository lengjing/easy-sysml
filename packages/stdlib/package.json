{
  "name": "@easy-sysml/stdlib",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "SysML v2 standard library definitions and loader for Langium workspace",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@easy-sysml/grammar": "workspace:*",
    "langium": "~3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
