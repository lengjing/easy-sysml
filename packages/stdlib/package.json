{
  "name": "@easy-sysml/stdlib",
  "version": "0.1.0",
  "type": "module",
  "license": "LGPL-3.0-or-later",
  "description": "SysML v2 / KerML standard library files and loader",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "scripts": {
    "generate:browser-bundle": "node scripts/bundle-browser.cjs",
    "build": "node scripts/bundle-browser.cjs && tsc --build",
    "test": "vitest run",
    "lint": "node scripts/bundle-browser.cjs && tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo src/generated"
  },
  "dependencies": {
    "@easy-sysml/parser": "workspace:*",
    "langium": "~4.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.8.3",
    "vitest": "^3.1.3"
  }
}
