{
  "name": "@easy-sysml/semantics",
  "version": "0.1.0",
  "description": "Core semantic analysis for SysML v2 — symbol table, scope resolution, type system, reference linking, and validation",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@easy-sysml/ast": "workspace:*",
    "@easy-sysml/protocol": "workspace:*",
    "@easy-sysml/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
