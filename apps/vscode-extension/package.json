{
  "name": "easy-sysml-vscode",
  "displayName": "Easy SysML",
  "description": "SysML v2 language support for Visual Studio Code",
  "version": "0.1.0",
  "license": "LGPL-3.0-or-later",
  "publisher": "easy-sysml",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:sysml",
    "onLanguage:kerml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sysml",
        "aliases": ["SysML", "sysml"],
        "extensions": [".sysml"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "kerml",
        "aliases": ["KerML", "kerml"],
        "extensions": [".kerml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sysml",
        "scopeName": "source.sysml",
        "path": "./sysml.tmLanguage.json"
      },
      {
        "language": "kerml",
        "scopeName": "source.sysml",
        "path": "./sysml.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc --build && node esbuild.mjs",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "vscode-languageclient": "~9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "~1.80.0",
    "esbuild": "~0.25.4",
    "typescript": "~5.8.3"
  }
}
