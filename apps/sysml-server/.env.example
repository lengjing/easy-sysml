# SysML Server
PORT=3001

# free-code server URL (set this when running free-code in server mode)
FREE_CODE_SERVER_URL=http://localhost:3002

# Optional auth token for free-code server
# FREE_CODE_AUTH_TOKEN=

# Directory to use as the working directory for free-code sessions
# FREE_CODE_WORK_DIR=./workspace

# SQLite database file path
DB_PATH=./data/sysml.db
