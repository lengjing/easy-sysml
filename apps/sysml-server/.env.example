# SysML Server
PORT=3001

# free-code server URL (set this when running free-code in server mode)
FREE_CODE_SERVER_URL=http://localhost:3002

# Optional auth token for free-code server
# FREE_CODE_AUTH_TOKEN=

# Directory to use as the working directory for free-code sessions
# FREE_CODE_WORK_DIR=./workspace

# SQLite database file path
DB_PATH=./data/sysml.db

# ─────────────────────────────────────────────────────────────────────
# AI provider configuration (pass these to the free-code server process)
# ─────────────────────────────────────────────────────────────────────
# DeepSeek (OpenAI-compatible):
#   CLAUDE_CODE_USE_OPENAI_COMPAT=1
#   OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_COMPAT_API_KEY=your-deepseek-api-key
#   OPENAI_COMPAT_PROVIDER=deepseek
#
# Qwen (OpenAI-compatible):
#   CLAUDE_CODE_USE_OPENAI_COMPAT=1
#   OPENAI_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   OPENAI_COMPAT_API_KEY=your-qwen-api-key
#   OPENAI_COMPAT_PROVIDER=qwen
#
# These variables must be set in the environment where you start free-code:
#   e.g.  CLAUDE_CODE_USE_OPENAI_COMPAT=1 OPENAI_COMPAT_API_KEY=xxx \
#         OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1 \
#         npx @anthropic-ai/claude-code --server --port 3002
