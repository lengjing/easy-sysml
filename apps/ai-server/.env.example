# Optional provider selection: gemini | deepseek | qwen | openai-compatible
AI_PROVIDER="gemini"

# Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# DeepSeek API
# DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# Qwen / DashScope API
# QWEN_API_KEY="YOUR_QWEN_API_KEY"

# Generic OpenAI-compatible API (e.g., local Ollama, LM Studio, Together AI)
# OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
# AI_BASE_URL="http://localhost:11434/v1"
# AI_MODEL="llama3.2"

# Server port — HTTP (SSE) on http://localhost:PORT/api/chat
#             — WebSocket on ws://localhost:PORT/api/ws
PORT=3001

# Agent settings
MAX_AGENT_STEPS=5
