    "@types/ws": "^8.18.1",
    "ai": "^6.0.168",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "langium": "~4.2.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vitest": "^4.1.5"
