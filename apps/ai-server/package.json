{
  "name": "@easy-sysml/ai-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Agent Server for SysML v2 modeling assistance with tool calling and grammar validation",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
