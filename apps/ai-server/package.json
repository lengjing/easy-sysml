{
  "name": "@easy-sysml/ai-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Agent Server for SysML v2 modeling — Vercel AI SDK with MCP tools (validate_sysml, get_stdlib_types)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --build",
